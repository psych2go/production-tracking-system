generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  wwUserId    String   @unique(map: "ww_user_id") @map("ww_user_id")
  name        String
  department  String?
  role        String   @default("worker") // admin, worker
  avatarUrl   String?  @map("avatar_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  batchesCreated   Batch[]           @relation("BatchCreator")
  progressRecords  ProgressRecord[]  @relation("ProgressOperator")
  auditLogs        AuditLog[]

  @@map("users")
}

model Product {
  id          Int      @id @default(autoincrement())
  model       String   @unique
  name        String?
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  batches Batch[]

  @@map("products")
}

model Batch {
  id         Int      @id @default(autoincrement())
  batchNo    String   @unique(map: "batch_no") @map("batch_no")
  batchType  String   @default("product") @map("batch_type") // product, trial
  productId  Int?     @map("product_id")
  quantity   Int      @default(0)
  status     String   @default("active") // active, completed, archived
  priority   String   @default("normal") // normal, urgent
  customerCode     String?   @map("customer_code")
  orderNo          String?   @map("order_no")
  packageType        String?   @map("package_type")
  customerDelivery   DateTime? @map("customer_delivery")
  productionDelivery DateTime? @map("production_delivery")
  trialContent       String?   @map("trial_content")
  quantityDetail     String?   @map("quantity_detail")
  notes            String?
  createdBy        Int?      @map("created_by")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  product         Product?         @relation(fields: [productId], references: [id])
  creator         User?            @relation("BatchCreator", fields: [createdBy], references: [id])
  progressRecords ProgressRecord[]
  scheduleOrders  ScheduleOrder[]

  @@map("batches")
}

model ProcessStage {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  name        String
  stageOrder  Int       @unique(map: "stage_order") @map("stage_order")
  isQcStage   Boolean   @default(false) @map("is_qc_stage")
  description String?

  progressRecords ProgressRecord[]
  scheduleOrders  ScheduleOrder[]

  @@map("process_stages")
}

model ProgressRecord {
  id              Int       @id @default(autoincrement())
  batchId         Int       @map("batch_id")
  stageId         Int       @map("stage_id")
  operatorId      Int       @map("operator_id")
  inputQuantity   Int?      @map("input_quantity")
  outputQuantity  Int?      @map("output_quantity")
  defectQuantity  Int       @default(0) @map("defect_quantity")
  defectType      String?   @map("defect_type")
  defectNotes     String?   @map("defect_notes")
  status          String    @default("completed") // completed, in_progress
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  batch    Batch        @relation(fields: [batchId], references: [id])
  stage    ProcessStage @relation(fields: [stageId], references: [id])
  operator User         @relation("ProgressOperator", fields: [operatorId], references: [id])

  @@unique([batchId, stageId], map: "batch_stage_unique")
  @@map("progress_records")
}

model PackageType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  category  String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("package_types")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  action    String                     // create, update, delete, login...
  entity    String                     // batch, progress, user, stage...
  entityId  Int?     @map("entity_id")
  detail    String?                    // JSON
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model ScheduleOrder {
  id       Int @id @default(autoincrement())
  stageId  Int @map("stage_id")
  batchId  Int @map("batch_id")
  orderNum Int @map("order_num")

  stage ProcessStage @relation(fields: [stageId], references: [id])
  batch Batch        @relation(fields: [batchId], references: [id])

  @@unique([stageId, batchId], map: "schedule_stage_batch_unique")
  @@map("schedule_orders")
}
